# OXO Menus - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Directus Backend Configuration
DIRECTUS_URL=https://your-directus-instance.example.com

# Optional: Directus Admin Credentials (for initial setup only)
# DIRECTUS_ADMIN_EMAIL=admin@example.com
# DIRECTUS_ADMIN_PASSWORD=your-secure-password

# App Configuration
APP_NAME=OXO Menus
APP_VERSION=1.0.0

# Environment (development, staging, production)
ENVIRONMENT=development

# Optional: Analytics/Monitoring
# SENTRY_DSN=https://your-sentry-dsn
# ANALYTICS_ID=your-analytics-id

# Optional: Feature Flags
# ENABLE_DEBUG_MENU=false
# ENABLE_OFFLINE_MODE=false
