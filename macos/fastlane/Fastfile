default_platform(:mac)

platform :mac do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    setup_ci if is_ci

    api_key = configure_api_key

    sync_certificates(api_key: api_key)

    build_mac_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.cedric06nice.oxomenus" => "match AppStore com.cedric06nice.oxomenus macos"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Push a new release build to App Store Connect"
  lane :release do
    setup_ci if is_ci

    api_key = configure_api_key

    sync_certificates(api_key: api_key)

    build_mac_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.cedric06nice.oxomenus" => "match AppStore com.cedric06nice.oxomenus macos"
        }
      }
    )

    upload_to_app_store(
      api_key: api_key,
      submit_for_review: false,
      skip_metadata: true,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Install certificates and provisioning profiles (CI: call before flutter build)"
  lane :install_profiles do
    setup_ci if is_ci

    api_key = configure_api_key

    sync_certificates(api_key: api_key)
  end

  desc "Initialize Match: generate certificates and profiles (run locally once)"
  lane :init_match do
    api_key = configure_api_key

    match(
      type: "appstore",
      platform: "macos",
      additional_cert_types: ["mac_installer_distribution"],
      api_key: api_key,
      readonly: false,
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
    )
  end

  desc "Nuke existing Match certificates (run locally to start over)"
  lane :nuke_match do
    api_key = configure_api_key

    match_nuke(
      type: "appstore",
      platform: "macos",
      api_key: api_key,
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
    )
  end

  private_lane :configure_api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )
  end

  private_lane :sync_certificates do |options|
    match(
      type: "appstore",
      platform: "macos",
      additional_cert_types: ["mac_installer_distribution"],
      api_key: options[:api_key],
      readonly: false,
      force: true,
      git_basic_authorization: ENV["MATCH_GIT_BASIC_AUTHORIZATION"]
    )
  end
end
